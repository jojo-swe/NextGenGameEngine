{
  "name": "nextgen-game-engine",
  "version-string": "0.1.0",
  "description": "Next-generation 3D game engine with real-time path tracing and GPU-driven rendering",
  "dependencies": [
    { "name": "spdlog", "version>=": "1.13.0" },
    { "name": "fmt", "version>=": "10.2.0" },
    { "name": "gtest", "version>=": "1.14.0" }
  ],
  "features": {
    "rendering": {
      "description": "Rendering stack dependencies (Vulkan path, mesh processing, tooling support)",
      "dependencies": [
        { "name": "volk" },
        { "name": "vulkan-memory-allocator" },
        { "name": "glm", "version>=": "0.9.9.8" },
        { "name": "meshoptimizer" },
        { "name": "imgui", "features": ["docking-experimental", "vulkan-binding", "win32-binding"] },
        { "name": "stb" },
        { "name": "cgltf" },
        { "name": "tracy" }
      ]
    },
    "gameplay": {
      "description": "Gameplay/runtime systems dependencies (physics, scripting, audio)",
      "dependencies": [
        { "name": "joltphysics", "version>=": "5.0.0" },
        { "name": "sol2", "version>=": "3.3.0" },
        { "name": "lua", "version>=": "5.4.6" },
        { "name": "miniaudio", "version>=": "0.11.21" }
      ]
    }
  },
  "builtin-baseline": "97b19caab97ab0c8d36c93230046c8c45fcd41d0",
  "overrides": [
    { "name": "glm", "version": "1.0.3" }
  ]
}
