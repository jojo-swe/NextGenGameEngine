        { "name": "vulkan-memory-allocator", "version>=": "3.0.1" },
        { "name": "glm", "version>=": "0.9.9.8" },
        { "name": "meshoptimizer", "version>=": "0.20" },
        { "name": "imgui", "version>=": "1.90.1", "features": ["docking-experimental", "vulkan-binding", "win32-binding"] },
        { "name": "stb", "version>=": "2023.12.15" },
        { "name": "cgltf", "version>=": "1.13" },
        { "name": "tracy", "version>=": "0.10" }
      ]
    },
    "gameplay": {
      "description": "Gameplay/runtime systems dependencies (physics, scripting, audio)",
      "dependencies": [
        { "name": "joltphysics", "version>=": "5.0.0" },
        { "name": "sol2", "version>=": "3.3.0" },
        { "name": "lua", "version>=": "5.4.6" },
        { "name": "miniaudio", "version>=": "0.11.21" }
      ]
    }
  },
  "builtin-baseline": "e238b4b4a4239829e1fde2c7db2ab668b65ae1dd"
